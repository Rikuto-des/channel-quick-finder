{
  "manifest_version": 3,
  "name": "Channel Quick Finder",
  "short_name": "Quick Finder",
  "version": "0.1.0",
  "description": "Discord ブラウザ版のサイドバーから、カテゴリ/チャネルをショートカット一発で検索 & ドリルダウン。⚠️非公式・自己責任で利用。",
  "author": "rikuto",
  "homepage_url": "https://github.com/Rikuto-des/channel-quick-finder",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://discord.com/channels/*"],
      "js": ["src/content.js"],
      "css": ["src/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-search": {
      "suggested_key": {
        "default": "Alt+Shift+K"
      },
      "description": "検索オーバーレイを開く / 閉じる"
    }
  }
}
